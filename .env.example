# Slack (Socket Mode — no public URL required)
SLACK_BOT_TOKEN=xoxb-your-bot-token
SLACK_APP_TOKEN=xapp-your-app-level-token

# GitHub (classic PAT: repo + read:org if needed)
GITHUB_TOKEN=ghp_your_personal_access_token
# Option A: allowlist (comma-separated owner/repo)
# GITHUB_REPOS=your-username/repo-a,your-username/repo-b

# Option B: all repos your PAT can access (recommended for solo use)
GITHUB_ALL_REPOS=true
# GITHUB_REPOS=*          # same as GITHUB_ALL_REPOS=true
# GITHUB_MAX_REPOS_LIST=200   # cap for list_repos / context

# LLM — DeepSeek (default, uses Anthropic-compatible API + tool calls)
LLM_PROVIDER=deepseek
DEEPSEEK_API_KEY=your-deepseek-api-key
# DEEPSEEK_BASE_URL=https://api.deepseek.com/anthropic
AGENT_MODEL=deepseek-v4-flash
# Harder tasks: deepseek-v4-pro

# Anthropic (optional — set LLM_PROVIDER=anthropic)
# LLM_PROVIDER=anthropic
# ANTHROPIC_API_KEY=sk-ant-...
# AGENT_MODEL=claude-haiku-4-5

# Agent limits
AGENT_MAX_TURNS=12
