# Slack (Socket Mode \u2014 no public URL required)
SLACK_BOT_TOKEN=xoxb-your-bot-token
SLACK_APP_TOKEN=xapp-your-app-level-token

# GitHub (classic PAT: repo + read:org if needed)
GITHUB_TOKEN=ghp_your_personal_access_token
# Option A: allowlist (comma-separated owner/repo)
# GITHUB_REPOS=your-username/repo-a,your-username/repo-b

# Option B: all repos your PAT can access (recommended for solo use)
GITHUB_ALL_REPOS=true
# GITHUB_REPOS=*          # same as GITHUB_ALL_REPOS=true
# GITHUB_MAX_REPOS_LIST=200   # cap for list_repos / context

# LLM \u2014 DeepSeek (default, uses Anthropic-compatible API + tool calls)
LLM_PROVIDER=deepseek
DEEPSEEK_API_KEY=your-deepseek-api-key
# DEEPSEEK_BASE_URL=https://api.deepseek.com/anthropic
AGENT_MODEL=deepseek-v4-flash
# Harder tasks: deepseek-v4-pro

# Anthropic (optional \u2014 set LLM_PROVIDER=anthropic)
# LLM_PROVIDER=anthropic
# ANTHROPIC_API_KEY=sk-ant-...
# AGENT_MODEL=claude-haiku-4-5

# Agent limits
AGENT_MAX_TURNS=12

# PR review reminder \u2014 daily summary of open PRs needing review
# Slack channel ID or name where reminders are posted (e.g. C01ABCDEFG or #pr-reviews)
SLACK_REVIEW_CHANNEL=
# Enable/disable the daily reminder (default: true)
REVIEW_REMINDER_ENABLED=true
# Time of day for the reminder in HH:MM (24-hour format, default: 09:00)
REVIEW_REMINDER_TIME=09:00
